    <div class="flex flex-col  menu_item p-[20px] shadow-md shadow-red-300/50">
        
            <% if item.img.attached? %>
            <%= image_tag url_for(item.img), class: "max-h-[250px] rounded-[15px] mb-[5px]" %>
            <% else %>
            <p>No image available</p>
            <% end %>
        
        <h5 class="font-[500]"><%= item["title"]%></h5>
        <p class="font-[100] text-[#8b8b8b]"><%= item["desc"] %></p>
        <h6 class="text-red-600 font-[600] mb-[5px]">RS: <%= item["price"]  %> </h6>
        <button class="cursor-pointer text-center h-[50px] bg-white text-red-700 rounded-[10px] font-[700] hover:bg-red-400 hover:text-black"  >+ ADD TO CART</button>
    </div>