<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
 <section class=" ">
    <div class="about-us relative  w-[100%] h-[98vh] bg-[#000000] text-white flex flex-col  items-center">
    <div class="title-container relative top-[50px] text-[2.75rem] font-[600] my-[3%] text-white">
                <h2 class="relative after:content-['']  after:bg-red-500 after:absolute after:bottom-0 after:right-0 after:w-[100%] after:h-[3px] ">Your <span class='text-red-500  '>BURGERJEE</span> CART <img class="inline-block w-[70px] h-[70px]" src="<%= asset_path("icons/foodCart.png") %>"></h2>
            </div>
        <div class="about-us-container relative flex flex-col items-center w-[80%] grid grid-cols-3 ">
            
            <% @food_item %>
            <div class=" flex flex-col w-100% lg:w-[90%]   lg:text-[1.25rem] sm:leading-[50px] ">
                <h5 class="font-[500]">Your selected item: <%= @food_item.title %></h5>
                <h6 class="text-white font-[300] mb-[5px]">RS: <%= @food_item.price   %></h6>
                <p class="font-[300] text-white"> Quantity(1-20): <input id="quantity-value" class="bg-[#36454F] text-white pl-2 rounded-[15px] w-[80px] border-[1px]" type="number" min="1" max="20" value=1 ><%=  %></p>
                <h6 class="text-white font-[300] mb-[5px]">Total cost: <span id="total-value" > <%= @food_item.price   %></span ></h6>
               
             

            </div>
        
        </div>
        <div class="w-[100%] flex flex-col justify-center items-center">
        <p class="w-[50%] h-[50px] text-[2.0rem] justify-center text-start">Grand Total:<span id="total-value" class="ml-[20px]">10000<span></p>
        <button onclick(document.addEventListener("DOMContentLoaded", function() {console.log("order Confirm")}) class="cursor-pointer text-center w-[50%] h-[50px] bg-white text-red-700 rounded-[10px] font-[700] hover:bg-red-400 hover:text-black"  >Confirm Order</button>
        <div>
        </div>

</section>
<script>
document.addEventListener("DOMContentLoaded", function() {
const itemQuantity = document.getElementById("quantity-value");
let totalCost = document.getElementById("total-value");
const price = <%= @food_item.price %>;

itemQuantity.addEventListener("input", function(){
   qty =parseInt(itemQuantity.value) || 0;
   totalCost.textContent = qty * price;
   console.log(totalCost)
});

});








</script>